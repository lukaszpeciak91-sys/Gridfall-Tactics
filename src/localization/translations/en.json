      "campaignAccordion": {
        "lore": {
          "Aggro": [
            "Immortal aristocrats sealed inside porcelain bodies.",
            "They preserve beauty, etiquette, and power through cruel rituals and harvested life-serums."
          ],
          "Tank": [
            "A reptilian solar empire marches toward extinction after a doomed prophecy.",
            "Its glory survives long after hope has faded."
          ],
          "Control": [
            "Survivors of a techno-occult catastrophe preserve their heads in glass vessels.",
            "They search for a signal capable of restoring reality itself."
          ],
          "Swarm": [
            "A planetary superorganism absorbed an entire biosphere into one consciousness.",
            "Every creature, growth, and instinct sings the same endless song."
          ],
          "Wardens": [
            "Neanderthal-descended clans cross the frozen equatorial tundra atop colossal mammoths.",
            "They endure between dying warmth and the cosmic Frost."
          ],
          "Attrition Swarm": [
            "The world ended on New Year's Eve 1999, but nobody realized.",
            "Decades later, the dead repeat forgotten routines they no longer understand."
          ],
          "Overclock": [
            "A state livestock weaponization program kept running after humanity vanished.",
            "Its files are official. Its animals are not safe."
          ]
        },
        "gameplay": {
          "Aggro": "Explosive aggression and ruthless pressure.",
          "Tank": "Endure, fortify, and crush through superior staying power.",
          "Control": "Control the battlefield through disruption and manipulation.",
          "Swarm": "Expand relentlessly until the battlefield belongs to you.",
          "Wardens": "Support your line, hold formation, and outlast the enemy.",
          "Attrition Swarm": "Gain value from loss, decay, and inevitable return.",
          "Overclock": "Force fights, disrupt lanes, and spend short overload windows."
        },
        "select": "SELECT",
        "descriptions": {
          "Aggro": [
            "Ladies and gentlemen, the Porcelain Court!",
            "They defeated death three centuries ago. Everyone else has regretted it ever since."
          ],
          "Tank": [
            "And here are the remnants of a proud civilization!",
            "Their Emperor promised them solar maidens. The delivery never arrived."
          ],
          "Control": [
            "Please welcome the Order of the Glass Head!",
            "They saved their heads. Reality was less fortunate."
          ],
          "Swarm": [
            "A big round of applause for the Spore Choir!",
            "Mom said to throw it away. It controls a planet now."
          ],
          "Wardens": [
            "A warm welcome to the Neanderthal Clans!",
            "In their world, you'll need a fur coat even at the equator."
          ],
          "Attrition Swarm": [
            "And here come the tireless partygoers!",
            "The world ended on New Year's Eve '99. They still haven't noticed."
          ],
          "Overclock": [
            "Please welcome Project H.E.R.D.!",
            "The government office is closed. The breeding directive is still active."
          ]
        }
      }
